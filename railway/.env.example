# ── Required ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Vector store (choose one) ──────────────────────────────────
VECTOR_STORE=supabase        # supabase | pinecone | qdrant

# ── Supabase (if VECTOR_STORE=supabase) ───────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Pinecone (if VECTOR_STORE=pinecone) ───────────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=

# ── Qdrant (if VECTOR_STORE=qdrant) ───────────────────────────
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=

# ── Server ─────────────────────────────────────────────────────
PORT=3008
