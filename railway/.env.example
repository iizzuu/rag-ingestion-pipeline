# ── Required ───────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Vector store (choose one) ──────────────────────────────────
VECTOR_STORE=supabase        # supabase | pinecone | qdrant

# ── Supabase (if VECTOR_STORE=supabase) ───────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Pinecone (if VECTOR_STORE=pinecone) ───────────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=

# ── Qdrant (if VECTOR_STORE=qdrant) ───────────────────────────
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=

# ── Server ─────────────────────────────────────────────────────
PORT=3050
